# ============================================================
# Horários Escolares — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores
# NUNCA commite o .env no repositório!
# ============================================================

# Banco de Dados
POSTGRES_USER=horarios
POSTGRES_PASSWORD=troque_esta_senha_segura
POSTGRES_DB=horarios_db

# Segurança JWT (gere com: openssl rand -hex 32)
SECRET_KEY=troque_por_uma_chave_secreta_de_32_caracteres_minimo

# Admin inicial (criado automaticamente no primeiro boot)
FIRST_ADMIN_EMAIL=admin@suaescola.edu.br
FIRST_ADMIN_PASSWORD=troque_esta_senha

# Porta exposta pela aplicação na VPS
APP_PORT=8080

# URL da API (deixe /api para produção atrás do nginx)
VITE_API_URL=/api

# Token expira em X minutos (padrão: 480 = 8 horas)
ACCESS_TOKEN_EXPIRE_MINUTES=480
